# Copy this file to .env and fill in your actual values.
# This file is safe to commit because it contains no real secrets.

PORT="3001"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pianohub?schema=public"
JWT_SECRET="change_this_to_a_long_random_secret_string"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
AUTH_COOKIE_NAME="access_token"
AUTH_COOKIE_SECURE="false"
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_MAX_AGE_MS="604800000"
TRANSACTION_ACCEPTED_TTL_HOURS="48"
STRIPE_SECRET_KEY="sk_test_change_me"
STRIPE_WEBHOOK_SECRET="whsec_change_me"
STRIPE_SUCCESS_URL="http://localhost:3000/payments/success"
STRIPE_CANCEL_URL="http://localhost:3000/payments/cancel"
STRIPE_CURRENCY="aud"
