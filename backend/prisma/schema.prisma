// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────
// Condition describes the physical state of a listed piano.
// Must stay in sync with backend/src/listings/condition.enum.ts.
enum Condition {
  new
  like_new
  good
  fair
  poor
}

// ── BookingStatus ─────────────────────────────────────────────────────────────
// Lifecycle of a booking request.
// Seller controls: pending → accepted | rejected
// Buyer controls:  pending → cancelled
enum BookingStatus {
  pending    // submitted by buyer, awaiting seller response
  accepted   // seller confirmed the viewing/purchase
  rejected   // seller declined
  cancelled  // buyer withdrew the request
}

// Status of a marketplace listing.
// active   = visible and available for enquiries/bookings
// sold     = completed transaction, no longer available
// archived = hidden by the owner without deleting the record
enum ListingStatus {
  active
  sold
  archived
}

// Status of a contact request sent by a buyer to a seller.
// open   = seller still needs to review/respond
// closed = conversation/request has been concluded
enum InquiryStatus {
  open
  closed
}

// Status of a purchase transaction between a buyer and a seller.
// initiated        = buyer has submitted a purchase intent
// seller_accepted  = seller agreed to move forward
// buyer_confirmed  = buyer confirmed the deal details
// completed        = the sale has been completed
// cancelled        = either party stopped the transaction before completion
enum TransactionStatus {
  initiated
  seller_accepted
  buyer_confirmed
  completed
  cancelled
}

// Status of a payment attempt tied to a transaction.
// pending   = payment intent/session created but not settled yet
// paid      = funds successfully captured in the simulated flow
// failed    = payment attempt failed
// cancelled = payment flow cancelled before completion
// refunded  = Stripe payment was successfully refunded after transaction cancellation
enum PaymentStatus {
  pending
  paid
  failed
  cancelled
  refunded
}

// ── User ──────────────────────────────────────────────────────────────────────
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // One user can own many listings (one-to-many)
  listings  Listing[]

  // Bookings this user has made as a buyer
  bookings  Booking[] @relation("BookingBuyer")

  // Listings this user has saved for later browsing
  savedListings SavedListing[]

  // Inquiries this user has sent as an interested buyer
  inquiries Inquiry[] @relation("InquiryRequester")

  // Transactions this user has initiated as a buyer
  transactions Transaction[] @relation("TransactionBuyer")

  // Payments this user has initiated as the paying buyer
  payments Payment[] @relation("PaymentBuyer")

  @@map("users")
}

// ── Listing ───────────────────────────────────────────────────────────────────
// Represents a piano listing posted by a user on the platform.
model Listing {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  brand       String?  // optional: piano brand (e.g. "Yamaha", "Kawai")
  condition   Condition // enforced at DB level via the Condition enum
  status      ListingStatus @default(active)
  location    String?  // optional: city or region

  // Foreign key — the user who created this listing
  ownerId     Int
  owner       User     @relation(fields: [ownerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // All booking requests made against this listing
  bookings    Booking[]

  // Images attached to this listing
  images      ListingImage[]

  // Users who have saved this listing
  savedBy     SavedListing[]

  // Contact requests submitted against this listing
  inquiries   Inquiry[]

  // Purchase transactions started against this listing
  transactions Transaction[]

  @@map("listings")
}

// ── Booking ───────────────────────────────────────────────────────────────────
// Represents a buyer's request to view or purchase a listed piano.
// A buyer may only have one active booking per listing (@@unique enforced at DB).
model Booking {
  id        Int           @id @default(autoincrement())

  // The listing being requested
  listingId Int
  listing   Listing       @relation(fields: [listingId], references: [id])

  // The user making the request (buyer).
  // Named relation "BookingBuyer" disambiguates from the Listing.owner → User path.
  buyerId   Int
  buyer     User          @relation("BookingBuyer", fields: [buyerId], references: [id])

  status    BookingStatus @default(pending)

  // Optional message from buyer to seller (e.g. preferred viewing time)
  message   String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // One buyer can only have one booking per listing at any time
  @@unique([listingId, buyerId])
  @@map("bookings")
}

// ── ListingImage ──────────────────────────────────────────────────────────────
// Stores metadata for images uploaded against a listing.
// The file itself lives on disk under uploads/; url is the public-accessible path.
model ListingImage {
  id        Int      @id @default(autoincrement())
  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   // public path e.g. "/uploads/listing-3-1234567890.jpg"
  order     Int      @default(0) // display order, 0 = first/cover image
  createdAt DateTime @default(now())

  @@map("listing_images")
}

// Stores a user's saved-listings relationship for marketplace browsing.
model SavedListing {
  id        Int      @id @default(autoincrement())
  userId    Int
  listingId Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("saved_listings")
}

// Stores a lightweight contact request from a buyer to the seller of a listing.
// This is intentionally not a full chat system yet.
model Inquiry {
  id          Int           @id @default(autoincrement())
  listingId   Int
  requesterId Int
  message     String
  status      InquiryStatus @default(open)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requester   User          @relation("InquiryRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([listingId, requesterId])
  @@map("inquiries")
}

// Stores a purchase intent / deal flow between a buyer and the seller of a listing.
// This is the business transaction layer, intentionally separate from payment integration.
model Transaction {
  id           Int               @id @default(autoincrement())
  listingId    Int
  buyerId      Int
  offeredPrice Float
  message      String?
  status       TransactionStatus @default(initiated)
  sellerAcceptedAt DateTime?
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  listing      Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer        User              @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([listingId, buyerId])
  @@map("transactions")
}

// Stores a payment attempt linked to a transaction.
// In phase 1 this is a simulated payment layer, not a real payment provider integration yet.
model Payment {
  id                Int           @id @default(autoincrement())
  transactionId     Int
  buyerId           Int
  amount            Float
  provider          String        @default("simulated")
  providerCheckoutSessionId String?
  providerPaymentId String?
  checkoutUrl       String?
  status            PaymentStatus @default(pending)
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  transaction       Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  buyer             User          @relation("PaymentBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([providerCheckoutSessionId])
  @@index([providerPaymentId])
  @@map("payments")
}
